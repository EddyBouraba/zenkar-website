# ──────────────────────────────────────────────
# Variables Docker Compose (frontend build args)
# Copier ce fichier en .env et remplir les valeurs
# ──────────────────────────────────────────────

# URL de l'API backend (utilisée par le frontend Vite)
VITE_API_URL=https://api.zenkar.fr

# Clé publique Cloudflare Turnstile (formulaires)
VITE_TURNSTILE_SITE_KEY=

# Mode maintenance : true = site caché aux visiteurs, false = site visible
VITE_MAINTENANCE_MODE=false

# ──────────────────────────────────────────────
# Variables backend (lues par backend/.env)
# Ces variables sont dans backend/.env — NE PAS les dupliquer ici
# ──────────────────────────────────────────────
